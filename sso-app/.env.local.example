# Copy to .env.local and fill in. Never commit .env.local.

# Required — sign and verify the JWT session cookie
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Microsoft Entra ID (required — all three)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# Comma-separated admin emails (optional)
# AUTH_ADMIN_EMAILS=alice@yourcorp.com,bob@yourcorp.com

# Where to send users after Microsoft login (Skyport-Web dev server by default)
NEXT_PUBLIC_SKYPORT_ORIGIN=http://localhost:5173

# Optional if the app is not on the default URL
# AUTH_URL=https://your-domain.com
