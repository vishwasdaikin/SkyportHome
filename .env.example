# Microsoft Entra ID (Azure AD) SSO
# Copy to .env or env.local and fill in from Azure Portal app registration.
# See docs/SSO_SETUP.md for setup steps.
# Do not use AUTH_MICROSOFT_ENTRA_ID_SECRET in this frontend app (SPA uses PKCE, no client secret).

# Real GUIDs only. Issuer tenant GUID must NOT be the same as the app client ID.
# AUTH_MICROSOFT_ENTRA_ID_ID → App registration → Overview → Application (client) ID
# AUTH_MICROSOFT_ENTRA_ID_ISSUER → …/login.microsoftonline.com/<Tenant ID>/v2.0 → Entra ID → Overview → Tenant ID
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# --- SkyportHome-Core (backend) ---
# Dev: Vite proxies /api/* to this origin. Match the port your Core API listens on.
SKYPORT_CORE_URL=http://localhost:3001
# Production build: browser calls this URL directly (Core must set CORS for your web origin).
# VITE_API_BASE_URL=https://your-core-api.example.com
