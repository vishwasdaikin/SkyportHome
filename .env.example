# --- Roadmap / business model Excel (optional) ---
# Defaults: *.xlsx in the project root. Point these at synced OneDrive paths to use shared team files.
# LOCAL_XLSX_FILE=/path/to/SkyportHome_Roadmap.xlsx
# (drives /local-data/test-sheet.json for FY26 / App Suite SkyportHome — not the Support Gantt page)
# Support → Test page · timeline reads only …/OneDrive*/Skyport-Web-Shared-Test/Test.xlsx (or Test.xls). No env override.
# Product Board reads only …/Skyport-Web-Shared-Test/Digital_Framework.xlsx (no env override).
# LOCAL_SKYPORTCARE_XLSX_FILE=/path/to/SkyportCare_Roadmap.xlsx
# LOCAL_DIGITAL_PLATFORMS_XLSX_FILE=/path/to/Digital_Platforms_Business_Model.xlsx
# Copy this block into `.env.local` (gitignored) on your machine. Vite dev + `npm run export-roadmaps` load `.env.local`.

# --- Production build URL (subpath deploy only) ---
# Unset or VITE_BASE_PATH=/ → assets at /assets/… (Vercel root, Netlify, custom domain at /).
# GitHub Pages at https://user.github.io/RepoName/ needs one of:
#   VITE_BASE_PATH=/RepoName/
#   OR in GitHub Actions only: VITE_GITHUB_PAGES=1 (uses GITHUB_REPOSITORY; see workflow file).

# Microsoft Entra ID (Azure AD) SSO
# Copy to .env or env.local and fill in from Azure Portal app registration.
# See docs/SSO_SETUP.md for setup steps.
# Do not use AUTH_MICROSOFT_ENTRA_ID_SECRET in this frontend app (SPA uses PKCE, no client secret).

# Real GUIDs only. Issuer tenant GUID must NOT be the same as the app client ID.
# AUTH_MICROSOFT_ENTRA_ID_ID → App registration → Overview → Application (client) ID
# AUTH_MICROSOFT_ENTRA_ID_ISSUER → …/login.microsoftonline.com/<Tenant ID>/v2.0 → Entra ID → Overview → Tenant ID
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# --- FY26 HCM playbook (Strategy nav + /strategy/fy26/hcm): on in `vite` dev only; off in production builds ---
# To show HCM on a deployed site, set:
# VITE_SHOW_FY26_HCM=true

# --- Test page (`/test-page` charts hub): on in `vite` dev only; off in production builds ---
# Care demo URLs under `/test-page/care-demo/*` stay available in production.
# To show the charts Test page on a deployed site, set:
# VITE_SHOW_TEST_PAGE=true

# --- Support top-nav + home Support CTA: on in `vite` dev; off in production builds ---
# To show Support on a deployed site, set:
# VITE_SHOW_SUPPORT_NAV=true

# --- Digital Tools–only public site (optional) ---
# When true: main nav shows only Home + Digital Tools; home page CTAs list only Digital Tools;
# any other route redirects to `/digital-tools`. Use for a production host that should not surface
# Strategy, App Suite, Support, care demo, etc. (still one full app build).
# VITE_DIGITAL_TOOLS_PUBLIC_SITE=true

# --- Temporary: no login (dev/demo only) ---
# VITE_SKIP_AUTH=1

# --- Site password (optional): visitors must enter this to view the app ---
# Set on Vercel for production. Default example: SkyportDemo (change in production!)
# VITE_SITE_PASSWORD=SkyportDemo

# --- Skyport-Core (backend OAuth, Web client + secret) ---
# Only set to 1 when Skyport-Core is running (e.g. port 3001). Unset = MSAL in browser or no auth if Entra empty.
# VITE_USE_BACKEND_AUTH=1
# Azure: add Web redirect URI http://localhost:5173/api/oauth/callback (not SPA).
# Dev: Vite proxies /api/* to Core so cookies are same-site as the app.
SKYPORT_CORE_URL=http://localhost:3001
# Production (Vercel): set to your deployed Core (must match Core FRONTEND_ORIGIN CORS).
# VITE_API_BASE_URL=https://skyport-core.vercel.app

# --- Daikin One Open API (thermostat integrator cloud; optional for demos / proxy) ---
# Docs: https://www.daikinone.com/openapi/documentation/index.html
# Base: https://integrator-api.daikinskyport.com — never expose keys in client bundles for production.
# VITE_DAIKIN_INTEGRATOR_API_KEY=
